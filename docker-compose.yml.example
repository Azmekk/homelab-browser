services:
  homelab-browser:
    # Either pull a tagged release from GHCR:
    image: ghcr.io/azmekk/homelab-browser:latest
    # ...or build the image locally from this repo:
    # build: .
    container_name: homelab-browser
    restart: unless-stopped
    ports:
      # Map whichever host port you like to the container's fixed :8080.
      - "8080:8080"
    volumes:
      # Persist the DB and uploaded service icons across container rebuilds.
      - ./data:/data
